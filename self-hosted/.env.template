# AWS Profile and region settings
AWS_PROFILE=default
AWS_REGION=us-east-1

# Config aggregator name (if using AWS Config)
CONFIG_AGGREGATOR=your_config_aggregator_name

# VPC ID (if you want to filter resources by VPC)
VPC_ID=your_vpc_id

# Discovery settings
CROSS_ACCOUNT_DISCOVERY=SELF_HOSTED

# Note: The AWS Account ID is now automatically detected from your AWS credentials 